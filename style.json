{
  "version": 8,
  "name": "OMM Default",
  "sources": {
    "omm": {
      "type": "vector",
      "url": "pmtiles://tiles.pmtiles"
    }
  },
  "layers": [
    {
      "id": "background",
      "paint": {
        "background-color": "#f8f4f0"
      },
      "type": "background"
    },
    {
      "id": "landuse-fill",
      "minzoom": 7,
      "paint": {
        "fill-color": [
          "match",
          [
            "get",
            "class"
          ],
          "forest",
          "#add19e",
          "grass",
          "#cdebb0",
          "meadow",
          "#cdebb0",
          "farmland",
          "#eef0d5",
          "residential",
          "#e8e0d8",
          "commercial",
          "#f2dad9",
          "industrial",
          "#ebdbe8",
          "cemetery",
          "#aacbaf",
          "#e8e0d8"
        ],
        "fill-opacity": 0.7
      },
      "source": "omm",
      "source-layer": "landuse",
      "type": "fill"
    },
    {
      "id": "natural-fill",
      "minzoom": 6,
      "paint": {
        "fill-color": [
          "match",
          [
            "get",
            "class"
          ],
          "wood",
          "#add19e",
          "scrub",
          "#c8d7ab",
          "grassland",
          "#cdebb0",
          "sand",
          "#f5e9c6",
          "beach",
          "#fff1ba",
          "glacier",
          "#ddecec",
          "#e8e0d8"
        ],
        "fill-opacity": 0.6
      },
      "source": "omm",
      "source-layer": "natural",
      "type": "fill"
    },
    {
      "id": "leisure-fill",
      "minzoom": 8,
      "paint": {
        "fill-color": [
          "match",
          [
            "get",
            "class"
          ],
          "park",
          "#c8facc",
          "garden",
          "#cdebb0",
          "golf_course",
          "#b5e3b5",
          "nature_reserve",
          "#cdebb0",
          "#c8facc"
        ],
        "fill-opacity": 0.6
      },
      "source": "omm",
      "source-layer": "leisure",
      "type": "fill"
    },
    {
      "filter": [
        "in",
        "class",
        "lake",
        "pond",
        "reservoir",
        "basin"
      ],
      "id": "water-fill",
      "paint": {
        "fill-color": "#aad3df",
        "fill-opacity": 0.8
      },
      "source": "omm",
      "source-layer": "water",
      "type": "fill"
    },
    {
      "filter": [
        "in",
        "class",
        "river",
        "stream",
        "canal",
        "drain",
        "ditch"
      ],
      "id": "water-line",
      "paint": {
        "line-color": "#aad3df",
        "line-width": [
          "match",
          [
            "get",
            "class"
          ],
          "river",
          3,
          "canal",
          2,
          1
        ]
      },
      "source": "omm",
      "source-layer": "water",
      "type": "line"
    },
    {
      "id": "building-fill",
      "minzoom": 13,
      "paint": {
        "fill-color": "#dfdbd7",
        "fill-opacity": 0.8
      },
      "source": "omm",
      "source-layer": "building",
      "type": "fill"
    },
    {
      "id": "building-outline",
      "minzoom": 14,
      "paint": {
        "line-color": "#c9c0b8",
        "line-width": 0.5
      },
      "source": "omm",
      "source-layer": "building",
      "type": "line"
    },
    {
      "id": "boundary",
      "minzoom": 2,
      "paint": {
        "line-color": "#9e9cab",
        "line-dasharray": [
          4,
          2
        ],
        "line-width": 1.5
      },
      "source": "omm",
      "source-layer": "boundary",
      "type": "line"
    },
    {
      "id": "railway",
      "minzoom": 8,
      "paint": {
        "line-color": "#bfbfbf",
        "line-width": 1.0
      },
      "source": "omm",
      "source-layer": "railway",
      "type": "line"
    },
    {
      "id": "highway-casing",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "minzoom": 7,
      "paint": {
        "line-color": "#c0b8b0",
        "line-width": [
          "match",
          [
            "get",
            "class"
          ],
          "motorway",
          8,
          "trunk",
          7,
          "primary",
          6,
          "secondary",
          5,
          "tertiary",
          4,
          "residential",
          3,
          "service",
          2,
          1.5
        ]
      },
      "source": "omm",
      "source-layer": "highway",
      "type": "line"
    },
    {
      "id": "highway-fill",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "minzoom": 4,
      "paint": {
        "line-color": [
          "match",
          [
            "get",
            "class"
          ],
          "motorway",
          "#e892a2",
          "motorway_link",
          "#e892a2",
          "trunk",
          "#f9b29c",
          "trunk_link",
          "#f9b29c",
          "primary",
          "#fcd6a4",
          "primary_link",
          "#fcd6a4",
          "secondary",
          "#f7fabf",
          "secondary_link",
          "#f7fabf",
          "tertiary",
          "#ffffff",
          "tertiary_link",
          "#ffffff",
          "#ffffff"
        ],
        "line-width": [
          "match",
          [
            "get",
            "class"
          ],
          "motorway",
          6,
          "trunk",
          5,
          "primary",
          4,
          "secondary",
          3,
          "tertiary",
          2.5,
          "residential",
          1.5,
          "service",
          1,
          0.75
        ]
      },
      "source": "omm",
      "source-layer": "highway",
      "type": "line"
    },
    {
      "id": "place-label",
      "layout": {
        "text-field": [
          "get",
          "name"
        ],
        "text-font": [
          "Open Sans Regular"
        ],
        "text-size": [
          "match",
          [
            "get",
            "class"
          ],
          "city",
          18,
          "town",
          14,
          "village",
          12,
          10
        ]
      },
      "minzoom": 4,
      "paint": {
        "text-color": "#333",
        "text-halo-color": "#fff",
        "text-halo-width": 1.5
      },
      "source": "omm",
      "source-layer": "place",
      "type": "symbol"
    }
  ]
}